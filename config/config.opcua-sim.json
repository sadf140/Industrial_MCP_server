{
  "server": {
    "name": "industrial-mcp-server",
    "version": "0.5.0-p3",
    "read_only": false
  },
  "transport": {
    "mode": "stdio"
  },
  "http": {
    "host": "127.0.0.1",
    "port": 8080
  },
  "opcua": {
    "connect_timeout_ms": 3000,
    "read_timeout_ms": 3000,
    "retry_count": 1,
    "retry_delay_ms": 200,
    "allow_raw_node_id": false,
    "write_enabled": true
  },
  "cache": {
    "enabled": true,
    "poll_interval_ms": 2000,
    "stale_after_ms": 10000
  },
  "security": {
    "enabled": true,
    "default_role": "operator",
    "hide_unauthorized_tools": true,
    "roles": {
      "viewer": [
        "get_gateway_health",
        "get_server_health",
        "list_devices",
        "get_device_state",
        "get_device_health",
        "get_alarm_history",
        "query_alarm_logs",
        "analyze_alarms",
        "diagnose_fault",
        "get_network_status",
        "read_node",
        "read_opcua_node",
        "read_device_snapshot",
        "get_device_status"
      ],
      "operator": [
        "get_gateway_health",
        "get_server_health",
        "list_devices",
        "get_device_state",
        "get_device_health",
        "get_alarm_history",
        "query_alarm_logs",
        "analyze_alarms",
        "diagnose_fault",
        "get_network_status",
        "read_node",
        "read_opcua_node",
        "read_device_snapshot",
        "get_device_status",
        "refresh_device_state",
        "acknowledge_alarm",
        "clear_cached_alarm",
        "prepare_device_action",
        "confirm_device_action",
        "cancel_device_action",
        "write_node",
        "call_device_method"
      ],
      "administrator": ["*"]
    }
  },
  "timeouts": {
    "mcp_request_ms": 5000,
    "tool_execution_ms": 3000,
    "opcua_request_ms": 1000
  },
  "reliability": {
    "max_retry_count": 1,
    "backoff_initial_ms": 100,
    "backoff_max_ms": 30000,
    "circuit_failure_threshold": 3,
    "circuit_cooldown_ms": 5000
  },
  "observability": {
    "metrics_enabled": false,
    "metrics_port": 9090
  },
  "storage": {
    "type": "jsonl",
    "sqlite_path": "../data/industrial-mcp.sqlite"
  },
  "audit": {
    "log_path": "../data/audit.opcua-sim.jsonl"
  },
  "alarm_log_path": "../data/alarms.example.jsonl",
  "devices": [
    {
      "id": "pump-1",
      "name": "Cooling Pump 1",
      "protocol": "opcua",
      "enabled": true,
      "endpoint": "opc.tcp://127.0.0.1:48520",
      "variables": [
        {
          "name": "temperature",
          "node_id": "ns=1;s=Pump1.Temperature",
          "data_type": "Double",
          "unit": "C",
          "description": "motor bearing temperature",
          "writable": true,
          "min": 0,
          "max": 120,
          "warn_max": 80,
          "alarm_max": 95
        },
        {
          "name": "current",
          "node_id": "ns=1;s=Pump1.Current",
          "data_type": "Double",
          "unit": "A",
          "description": "motor phase current",
          "writable": true,
          "min": 0,
          "max": 30,
          "warn_max": 16,
          "alarm_max": 20
        },
        {
          "name": "running",
          "node_id": "ns=1;s=Pump1.Running",
          "data_type": "Boolean",
          "unit": "",
          "description": "running feedback",
          "writable": true
        },
        {
          "name": "label",
          "node_id": "ns=1;s=Pump1.Label",
          "data_type": "String",
          "unit": "",
          "description": "simulated equipment label",
          "writable": true
        }
      ],
      "methods": [
        {
          "name": "reset_trip",
          "object_id": "ns=0;i=85",
          "method_id": "ns=1;i=1000",
          "description": "safe reset trip method exposed by opcua-sim-server",
          "enabled": true,
          "requires_confirmation": true,
          "input_types": ["String"],
          "mock_result": ["reset accepted"]
        }
      ]
    }
  ]
}
