{
  "server": {
    "name": "industrial-mcp-server",
    "version": "0.4.0-p2",
    "read_only": false
  },
  "opcua": {
    "connect_timeout_ms": 3000,
    "read_timeout_ms": 3000,
    "retry_count": 1,
    "retry_delay_ms": 200,
    "allow_raw_node_id": false,
    "write_enabled": true
  },
  "cache": {
    "enabled": true,
    "poll_interval_ms": 2000,
    "stale_after_ms": 10000
  },
  "audit": {
    "log_path": "../data/audit.opcua-sim.jsonl"
  },
  "alarm_log_path": "../data/alarms.example.jsonl",
  "devices": [
    {
      "id": "pump-1",
      "name": "Cooling Pump 1",
      "endpoint": "opc.tcp://127.0.0.1:48520",
      "variables": [
        {
          "name": "temperature",
          "node_id": "ns=1;s=Pump1.Temperature",
          "data_type": "Double",
          "unit": "C",
          "description": "motor bearing temperature",
          "writable": true,
          "warn_max": 80,
          "alarm_max": 95
        },
        {
          "name": "current",
          "node_id": "ns=1;s=Pump1.Current",
          "data_type": "Double",
          "unit": "A",
          "description": "motor phase current",
          "writable": true,
          "warn_max": 16,
          "alarm_max": 20
        },
        {
          "name": "running",
          "node_id": "ns=1;s=Pump1.Running",
          "data_type": "Boolean",
          "unit": "",
          "description": "running feedback",
          "writable": true
        },
        {
          "name": "label",
          "node_id": "ns=1;s=Pump1.Label",
          "data_type": "String",
          "unit": "",
          "description": "simulated equipment label",
          "writable": true
        }
      ]
    }
  ]
}
