{
  "server": {
    "name": "industrial-mcp-server",
    "version": "0.5.0-p3",
    "read_only": true
  },
  "transport": {
    "mode": "stdio"
  },
  "http": {
    "host": "127.0.0.1",
    "port": 8080
  },
  "opcua": {
    "connect_timeout_ms": 3000,
    "read_timeout_ms": 3000,
    "retry_count": 1,
    "retry_delay_ms": 200,
    "allow_raw_node_id": false,
    "write_enabled": false
  },
  "cache": {
    "enabled": true,
    "poll_interval_ms": 2000,
    "stale_after_ms": 10000
  },
  "security": {
    "enabled": true,
    "default_role": "viewer",
    "hide_unauthorized_tools": true
  },
  "timeouts": {
    "mcp_request_ms": 5000,
    "tool_execution_ms": 3000,
    "opcua_request_ms": 1000
  },
  "reliability": {
    "max_retry_count": 1,
    "backoff_initial_ms": 100,
    "backoff_max_ms": 30000,
    "circuit_failure_threshold": 3,
    "circuit_cooldown_ms": 5000
  },
  "observability": {
    "metrics_enabled": false,
    "metrics_port": 9090
  },
  "storage": {
    "type": "jsonl",
    "sqlite_path": "../data/industrial-mcp.sqlite"
  },
  "audit": {
    "log_path": "../data/audit.example.jsonl"
  },
  "alarm_log_path": "../data/alarms.example.jsonl",
  "devices": [
    {
      "id": "pump-1",
      "name": "Cooling Pump 1",
      "protocol": "opcua",
      "enabled": true,
      "endpoint": "mock://pump-1",
      "variables": [
        {
          "name": "temperature",
          "node_id": "ns=2;s=Pump1.Temperature",
          "data_type": "Double",
          "unit": "C",
          "description": "motor bearing temperature",
          "mock_value": 82.5,
          "writable": false,
          "warn_max": 80,
          "alarm_max": 95
        },
        {
          "name": "current",
          "node_id": "ns=2;s=Pump1.Current",
          "data_type": "Double",
          "unit": "A",
          "description": "motor phase current",
          "mock_value": 14.2,
          "writable": false,
          "warn_max": 16,
          "alarm_max": 20
        },
        {
          "name": "running",
          "node_id": "ns=2;s=Pump1.Running",
          "data_type": "Boolean",
          "unit": "",
          "description": "running feedback",
          "mock_value": true,
          "writable": false
        }
      ],
      "methods": [
        {
          "name": "reset_trip",
          "object_id": "ns=0;i=85",
          "method_id": "ns=1;i=1000",
          "description": "mock reset trip method for safe client validation",
          "enabled": true,
          "requires_confirmation": true,
          "input_types": ["String"],
          "mock_result": ["reset accepted"]
        }
      ]
    }
  ]
}
